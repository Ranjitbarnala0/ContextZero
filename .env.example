# ContextZero V2 — Environment Configuration
# Copy to .env and fill in your values.
#
# Sections marked (MCP) apply to the MCP stdio bridge.
# Sections marked (REST) apply to the Express HTTP API.
# Sections marked (BOTH) apply to both.

# ──────────── Database (BOTH) ────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scg_v2
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_BEFORE_DEPLOYING
DB_MAX_CONNECTIONS=20
# DB_IDLE_TIMEOUT_MS=30000
# DB_CONNECTION_TIMEOUT_MS=5000
# DB_SLOW_QUERY_MS=500
# Maximum time (ms) a single SQL statement may run before being killed.
# Prevents runaway queries from locking the database. 0 = no limit.
# DB_STATEMENT_TIMEOUT_MS=30000
# Maximum time to wait for the migration advisory lock before startup fails.
# DB_MIGRATION_LOCK_TIMEOUT_MS=10000
# Maximum time a single migration statement may run.
# DB_MIGRATION_STATEMENT_TIMEOUT_MS=300000

# ──────────── Server (REST) ────────────
SCG_PORT=3100
SCG_HOST=0.0.0.0
NODE_ENV=production

# Version reported in health checks and logs (BOTH)
# SCG_VERSION=2.0.0

# ──────────── Authentication (REST) ────────────
# Comma-separated API keys. If empty, ALL requests are rejected (fail-closed).
# Generate with: openssl rand -hex 32
SCG_API_KEYS=your-secret-key-here

# ──────────── Security (REST) ────────────
# Comma-separated allowed repository base paths.
# Repos outside these paths are rejected (fail-closed if empty).
# SCG_ALLOWED_BASE_PATHS=/home/repos,/var/projects

# Comma-separated CORS origins. If empty, no CORS headers are emitted.
# SCG_CORS_ORIGINS=http://localhost:3000,https://your-frontend.example.com

# Set when running behind a reverse proxy/load balancer.
# Examples: true, 1, loopback
# SCG_TRUST_PROXY=true
# Emit HSTS only on HTTPS requests (or proxied HTTPS requests).
# SCG_HSTS_MAX_AGE_SECONDS=31536000
# Auto-recover stale non-terminal transactions left behind by crashes.
# SCG_STALE_TRANSACTION_MS=21600000
# SCG_STALE_TRANSACTION_BATCH_SIZE=100

# ──────────── Logging (BOTH) ────────────
# debug | info | warn | error | fatal
LOG_LEVEL=info

# ──────────── Prerequisites ────────────
# PostgreSQL must have the pg_trgm extension installed:
#   CREATE EXTENSION IF NOT EXISTS pg_trgm;
# Without it, homolog similarity searches will fail.
